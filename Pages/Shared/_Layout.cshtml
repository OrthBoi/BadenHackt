@using Microsoft.AspNetCore.Mvc.Rendering
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DataLink Technology</title>
    <link rel="stylesheet" href="~/css/common_styles.css" asp-append-version="true" />
</head>
<body>
    <header id="homepageLogoAndTitle">
        <div id="homepageLogo">
            <img src="~/images/logo.png" alt="Logo" />
        </div>
        <div id="homepageTitle"><h1>DataLink Technology©</h1></div>
    </header>

    <main id="mainWrapping">
        @RenderBody() 
    </main>

    <footer>
        <div id="footerWrapping">
            <p>&copy; 2026 DataLink Technology.</p>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>